<!DOCTYPE html>
<html lang="en">
<body style="margin:0;padding:0;background:#f3f4f6;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6;padding:32px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.08);">

        <!-- Header -->
        <tr>
          <td style="background:#dc2626;padding:28px 32px;">
            <h1 style="margin:0;color:#fff;font-size:22px;">&#x1F6A8; Security Challenge Triggered</h1>
            <p style="margin:6px 0 0;color:#fca5a5;font-size:14px;">
              {{Type}} &mdash; Severity: <strong>{{Severity}}</strong>
            </p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:28px 32px;">
            <p style="margin:0 0 20px;font-size:13px;color:#6b7280;border-bottom:1px solid #e5e7eb;padding-bottom:16px;">
              A security challenge was triggered. Review the details below and resolve in the Admin Dashboard.
            </p>

            <table width="100%" cellpadding="0" cellspacing="0">
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;width:160px;">User ID</td>
                <td style="padding:10px 0;font-size:14px;font-weight:bold;color:#111827;">{{UserId}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Email</td>
                <td style="padding:10px 0;font-size:14px;font-weight:bold;color:#111827;">{{UserEmail}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Detected Pattern</td>
                <td style="padding:10px 0;font-size:14px;font-weight:bold;color:#dc2626;">{{DetectedPattern}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Triggered on Page</td>
                <td style="padding:10px 0;font-size:13px;color:#374151;word-break:break-all;">{{Url}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Timestamp</td>
                <td style="padding:10px 0;font-size:13px;color:#374151;">{{Timestamp}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Auth Context</td>
                <td style="padding:10px 0;font-size:13px;color:#374151;">{{Context}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Session ID</td>
                <td style="padding:10px 0;font-size:11px;color:#9ca3af;">{{SessionId}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Platform</td>
                <td style="padding:10px 0;font-size:13px;color:#374151;">{{Platform}}</td>
              </tr>
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Browser</td>
                <td style="padding:10px 0;font-size:11px;color:#374151;word-break:break-all;">{{UserAgent}}</td>
              </tr>
              <tr>
                <td style="padding:10px 0;color:#6b7280;font-size:13px;">Location</td>
                <td style="padding:10px 0;font-size:13px;color:#374151;">{{Location}}</td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#fef2f2;border-top:1px solid #fecaca;padding:16px 32px;">
            <p style="margin:0;font-size:12px;color:#b91c1c;">
              &#x26A0;&#xFE0F; Log in to the Admin Dashboard to review and resolve this alert.
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
